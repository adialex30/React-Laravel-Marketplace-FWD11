            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"name\": \"UI Kit Premium\",\n  \"description\": \"Paket UI Kit lengkap untuk Figma\",\n  \"price\": 150000,\n  \"stock\": 999\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
