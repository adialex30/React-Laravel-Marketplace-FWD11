                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "});",
                  "// Simpan product_id untuk request Update dan Delete",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"product_id\", jsonData.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
